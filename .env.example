OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

# Optional cost/model controls
OPENAI_TRIAGE_MODEL=gpt-4.1-nano
OPENAI_GUARDRAIL_MODEL=gpt-4.1-mini
OPENAI_ANSWER_MODEL=gpt-4.1-mini

# Next.js uses this server-only URL to proxy to the Python backend.
PYTHON_AGENT_URL=http://127.0.0.1:8000

# Set this to your search provider's effective per-request cost.
WEB_SEARCH_COST_PER_CALL_USD=0.01
